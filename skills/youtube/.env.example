# OpenRouter credentials and model selection, used by scripts/make_resume.py.
#
# Copy this file to `.env` in this skill's directory to set a personal
# default key (used as a fallback wherever the skill is invoked from), or
# put a project-level `.env` in whatever directory you run the skill from -
# either is picked up automatically.

# Your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model id to use for generating the resume, e.g.
#   openai/gpt-4o-mini
#   anthropic/claude-3.5-sonnet
#   google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini
